create table public."ÁGUA" (
  id bigint generated by default as identity not null,
  "USUÁRIOS" text not null,
  "CONSUMO DE ÁGUA" text not null,
  "REUSO DA ÁGUA" text not null,
  "APROXIMIDADE DA ÁGUA" text not null,
  "PAIS" text not null,
  constraint ÁGUA_pkey primary key (id),
  constraint ÁGUA_APROXIMIDADE DA ÁGUA_key unique ("APROXIMIDADE DA ÁGUA"),
  constraint ÁGUA_CONSUMO DE ÁGUA_key unique ("CONSUMO DE ÁGUA"),
  constraint ÁGUA_REUSO DA ÁGUA_key unique ("REUSO DA ÁGUA"),
  constraint ÁGUA_USUÁRIOS_key unique ("USUÁRIOS")
) TABLESPACE pg_default;
