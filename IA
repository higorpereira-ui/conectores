CREATE  TABLE public."IA" (
  id bigint GENERATED BY DEFAULT AS IDENTITY NOT NULL,
  "PAÍS" text NULL,
  "EMPRESA" text NOT NULL,
  "IA MAIS UTILIZADA" text NOT NULL,
  "USUÁRIOS" text NULL,
  "TIPO DE RESFRIAMENTO" text NOT NULL,
  "INTERAÇÕES/DIA" smallint NULL,
  "CUSTO ANUAL" text NULL,
  "TEMPERATURA MÉDIA" text NOT NULL,
  "PICO DE USO" smallint NULL,
  CONSTRAINT tabela 2_pkey PRIMARY KEY (id),
  CONSTRAINT IA_EMPRESA_key UNIQUE ("EMPRESA"),
  CONSTRAINT IA_IA MAIS UTILIZADA_key UNIQUE ("IA MAIS UTILIZADA"),
  CONSTRAINT IA_TEMPERATURA MÉDIA_key UNIQUE ("TEMPERATURA MÉDIA"),
  CONSTRAINT IA_TIPO DE RESFRIAMENTO_key UNIQUE ("TIPO DE RESFRIAMENTO"),
  CONSTRAINT IA_EMPRESA_fkey FOREIGN KEY ("EMPRESA") REFERENCES "ÁGUA"("USUÁRIOS"),
  CONSTRAINT IA_IA MAIS UTILIZADA_fkey FOREIGN KEY ("IA MAIS UTILIZADA") REFERENCES "ÁGUA"("CONSUMO DE ÁGUA"),
  CONSTRAINT IA_CUSTO ANUAL_fkey FOREIGN KEY ("CUSTO ANUAL") REFERENCES "ÁGUA"("REUSO DA ÁGUA")
) TABLESPACE pg_default;
