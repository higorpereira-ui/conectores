CREATE  TABLE public."GEOGRAFIA" (
  id bigint GENERATED BY DEFAULT AS IDENTITY NOT NULL,
  "CONTINENTE" text NULL,
  "CIDADE" text NOT NULL,
  "REGIÃO" text NOT NULL,
  "CLIMA" text NOT NULL,
  "REGULAMENTAÇÃO AMBIENTAL" text NULL,
  "PAIS" text NOT NULL,
  CONSTRAINT Tabela 3_pkey PRIMARY KEY (id),
  CONSTRAINT GEOGRAFIA_REGIÃO_key2 UNIQUE ("REGIÃO"),
  CONSTRAINT GEOGRAFIA_REGIÃO_key1 UNIQUE ("REGIÃO"),
  CONSTRAINT GEOGRAFIA_PAIS_key UNIQUE ("PAIS"),
  CONSTRAINT GEOGRAFIA_CIDADE_key UNIQUE ("CIDADE"),
  CONSTRAINT GEOGRAFIA_REGIÃO_key UNIQUE ("REGIÃO"),
  CONSTRAINT GEOGRAFIA_CLIMA_key UNIQUE ("CLIMA"),
  CONSTRAINT GEOGRAFIA_REGIÃO_fkey FOREIGN KEY ("REGIÃO") REFERENCES "IA"("IA MAIS UTILIZADA"),
  CONSTRAINT GEOGRAFIA_CLIMA_fkey FOREIGN KEY ("CLIMA") REFERENCES "IA"("TEMPERATURA MÉDIA"),
  CONSTRAINT GEOGRAFIA_CIDADE_fkey FOREIGN KEY ("CIDADE") REFERENCES "IA"("EMPRESA")
) TABLESPACE pg_default;
